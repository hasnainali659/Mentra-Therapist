# Copy to .env and fill in. OpenAI: embeddings + chat fallback. DeepSeek: primary chat.

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Used when DeepSeek fails (and always for embeddings):
# OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
# Optional overrides:
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=session_memories
